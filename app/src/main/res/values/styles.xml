<resources>

    <style name="SplashScreenTheme" parent="Theme.SplashScreen">
        <!--是否是亮色主题-->
        <item name="isLightTheme">true</item>
        <!--纯色背景-->
        <item name="windowSplashScreenBackground">#ffffff</item>
        <!--中间图标 api32可以设置为AnimationDrawable 和 AnimatedVectorDrawable动画时长使用windowSplashScreenAnimationDuration控制，api33及以上则会自动推算 -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/img_splash</item>
        <!--图标背景色-->
        <item name="windowSplashScreenIconBackgroundColor">#ffffff</item>
        <!--普通Activity使用的主题-->
        <item name="postSplashScreenTheme">@style/AppTheme</item>
    </style>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryDark">@color/primaryDarkColor</item>
        <item name="colorAccent">@color/secondaryColor</item>
        <item name="android:actionBarSize">56dp</item>
        <item name="android:spinnerItemStyle">@style/SpType</item>
        <item name="android:spinnerDropDownItemStyle">@style/SpType</item>
    </style>

    <!--默认单行单行-->
    <style name="EtNormal">
        <item name="android:inputType">text</item>
        <item name="android:lines">1</item>
        <item name="android:background">@drawable/sha_outlinebox</item>
        <item name="android:textSize">16sp</item>
        <!--        <item name="android:textColor">@color/colorTextPrimaryLight</item>-->
        <!--        <item name="android:textColorHint">@color/colorTextDisableLight</item>-->
    </style>
    <!--多行编辑框-->
    <style name="EtNormalMulti">
        <item name="android:gravity">top</item>
        <item name="android:inputType">textMultiLine</item>
        <item name="android:minLines">5</item>
        <item name="android:background">@drawable/sha_outlinebox</item>
        <item name="android:textSize">16sp</item>
        <!--        <item name="android:textColor">@color/colorTextPrimaryLight</item>-->
        <!--        <item name="android:textColorHint">@color/colorTextDisableLight</item>-->
    </style>

    <style name="ToolBar.Theme" parent="@style/ThemeOverlay.AppCompat.Dark">
        <item name="android:tint">@android:color/white</item>
    </style>

    <style name="ToolBar.PopTheme" parent="@style/ThemeOverlay.AppCompat.Light" />

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="SpType"><!--parent="TxtMedium"-->
        <item name="android:padding">8dp</item>
    </style>
    <!--Dialog样式Activity-->
    <style name="Dialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="windowNoTitle">true</item>　　　　　　　
    </style>
</resources>
